# Usuario de Twitter (ej: CRKingdomEN)
TWITTER_USER_ID=1331494367329095681

# Token de API de Rettiwt (opcional pero recomendado)
# Obtener en: https://chromewebstore.google.com/detail/x-auth-helper/igpkhkjmpdecacocghpgkghdcmcmpfhp
RETTIWT_API_KEY=

# ID del canal de WhatsApp (ej: 120363XXX@g.us)
# Ejecuta: npm run list-channels para ver tus canales
WHATSAPP_CHANNEL_ID=120363XXX@g.us

# API Key de DeepSeek para traducción
# Obtener en: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
